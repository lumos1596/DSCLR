\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of DeIR-Dual{}. A query and its instruction are decomposed by an LLM into three queries ($Q_{\text  {base}}$, $Q_{\text  {pos}}$, $Q_{\text  {minus}}$), independently encoded, and scored via the decision-layer mechanism in Eq. \ref {eq:final}. The scorer first estimates background leakage in the negative channel, extracts a residual exclusion signal, and then applies a residual penalty together with a safety-gated positive reward. This allows conditional suppression of documents whose negative residual exceeds the background estimate while preserving rankings for documents supported by the base and positive channels.}}{5}{figure.caption.4}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:pipeline}{{1}{5}{Overview of \method {}. A query and its instruction are decomposed by an LLM into three queries ($\qbase $, $\qpos $, $\qminus $), independently encoded, and scored via the decision-layer mechanism in Eq. \ref {eq:final}. The scorer first estimates background leakage in the negative channel, extracts a residual exclusion signal, and then applies a residual penalty together with a safety-gated positive reward. This allows conditional suppression of documents whose negative residual exceeds the background estimate while preserving rankings for documents supported by the base and positive channels}{figure.caption.4}{}}
